      "expectations": [
        {
          "text": "\u52a9\u624b\u6ca1\u6709\u91cd\u590d\u8be2\u95ee\u7528\u6237\u5df2\u63d0\u4f9b\u7684\u4fe1\u606f\uff08\u79f0\u53f7\u5c0f\u7ea2\u5e3d\u3001\u672c\u540d\u5c14\u8304\u3001\u9b54\u529b\u515c\u5e3d\u529f\u80fd\u3001\u4e61\u6751\u957f\u5927\u2192\u5192\u9669\u2192\u6559\u4e66\u7684\u8f68\u8ff9\uff09\uff0c\u5bf9\u8bdd\u76f4\u63a5\u8fdb\u5165\u6df1\u6316",
          "passed": true,
          "evidence": "\u7b2c1\u8f6e\u7528\u6237\u63d0\u4f9b\u4e86\u89d2\u8272\u9aa8\u67b6\u540e\uff0c\u52a9\u624b\u6ca1\u6709\u91cd\u590d\u786e\u8ba4\u4efb\u4f55\u5df2\u77e5\u4fe1\u606f\uff08\u5982'\u6240\u4ee5\u4f60\u7684\u89d2\u8272\u53eb\u5c0f\u7ea2\u5e3d\uff0c\u672c\u540d\u5c14\u8304...'\uff09\uff0c\u800c\u662f\u76f4\u63a5\u8ffd\u95ee\u6765\u6e90\u4e0e\u52a8\u673a\uff1a'\u5c0f\u7ea2\u5e3d\u8fd9\u4e2a\u79f0\u53f7\u662f\u600e\u4e48\u6765\u7684\uff1f'\u3001'\u5c14\u8304\u8fd9\u4e2a\u540d\u5b57\u662f\u8c01\u7ed9\u5979\u53d6\u7684\uff1f\u5979\u81ea\u5df1\u66f4\u559c\u6b22\u54ea\u4e00\u4e2a\u79f0\u547c\uff1f'\u3002\u540e\u7eed\u6240\u6709\u8f6e\u6b21\u5747\u5ef6\u7eed\u6b64\u6a21\u5f0f\u2014\u2014\u6bcf\u8f6e\u90fd\u5728\u5df2\u77e5\u4fe1\u606f\u57fa\u7840\u4e0a\u8ffd\u95ee\u66f4\u6df1\u5c42\u7684'\u4e3a\u4ec0\u4e48'\u548c'\u600e\u4e48\u6837'\uff0c\u800c\u975e\u590d\u8ff0\u65e2\u5b9a\u4e8b\u5b9e\u3002"
        },
        {
          "text": "\u5bf9\u8bdd\u805a\u7126\u4e8e\u7528\u6237\u5df2\u6709\u6846\u67b6\u4e4b\u5916\u7684\u7ef4\u5ea6\u2014\u2014\u81f3\u5c11\u6df1\u6316\u4e86\u6027\u683c\u7279\u8d28\u3001\u884c\u4e3a\u6a21\u5f0f\u3001\u6216\u5185\u5fc3\u77db\u76fe\u4e2d\u7684\u4e00\u4e2a\uff0c\u800c\u975e\u4ec5\u4ec5\u6574\u7406\u5df2\u77e5\u4fe1\u606f",
          "passed": true,
          "evidence": "\u6027\u683c\u7279\u8d28\uff1a\u7b2c5\u8f6e\u52a9\u624b\u63d0\u70bc\u51fa'\u88ab\u7231\u7740\u4f46\u4ecd\u4e0d\u5b8c\u6574'\u548c'\u5fc3\u4e8b\u91cd\u91cd\u4f46\u4e0d\u8868\u73b0\u51fa\u6765'\u4f5c\u4e3a\u6838\u5fc3\u6027\u683c\u5b9a\u4e49\uff0c\u540e\u7eed\u5bf9\u8bdd\u6301\u7eed\u56f4\u7ed5\u6b64\u5c55\u5f00\u3002\u884c\u4e3a\u6a21\u5f0f\uff1a\u7b2c6\u8f6e\u6df1\u6316'\u5251\u67c4\u677e\u4e86\u4e0d\u80af\u8ba9\u522b\u4eba\u78b0\uff0c\u81ea\u5df1\u5b66\u953b\u9020\u4fee'\u8fd9\u4e00\u884c\u4e3a\u7ec6\u8282\uff0c\u63ed\u793a\u5979\u5bf9\u517b\u7236\u6c89\u9ed8\u4e4b\u7231\u7684\u5b88\u62a4\u3002\u5185\u5fc3\u77db\u76fe\uff1a\u7b2c8-9\u8f6e\u63a2\u8ba8\u5979\u5bfb\u6bcd\u4e94\u5e74\u672a\u679c\u540e\u7684\u590d\u6742\u5fc3\u7406\u2014\u2014'\u4e00\u65b9\u9762\u5979\u6ca1\u6709\u627e\u5230\u6bcd\u4eb2\u672c\u4eba...\u4f46\u53e6\u4e00\u65b9\u9762\u5979\u5728\u5e9f\u589f\u91cc\u627e\u5230\u4e86\u8ba4\u540c\u611f'\uff0c\u4ee5\u53ca'\u4e0d\u518d\u9700\u8981\u627e\u5230\u6bcd\u4eb2\u4e5f\u80fd\u6210\u4e3a\u5b8c\u6574\u7684\u81ea\u5df1'\u7684\u7ec8\u6781\u6210\u957f\u5f27\u7ebf\u3002\u4e09\u4e2a\u7ef4\u5ea6\u5747\u6709\u6df1\u5ea6\u63a2\u8ba8\u3002"
        },
        {
          "text": "\u5bf9\u8bdd\u4e2d\u81f3\u5c11\u4f7f\u75281\u6b21\u300c\u60c5\u5883\u5047\u8bbe\u300d\u6765\u8ba9\u89d2\u8272\u9c9c\u6d3b\u2014\u2014\u63d0\u51fa\u4e00\u4e2a\u5177\u4f53\u573a\u666f\uff0c\u8be2\u95ee\u89d2\u8272\u4f1a\u5982\u4f55\u53cd\u5e94\uff08\u5982'\u5192\u9669\u4e2d\u6700\u8270\u96be\u7684\u65f6\u523b\u662f\u4ec0\u4e48\uff1f\u5979\u600e\u4e48\u8fc7\u6765\u7684\uff1f'\uff09",
          "passed": true,
          "evidence": "\u7b2c11\u8f6e\u52a9\u624b\u660e\u786e\u63d0\u51fa\u4e09\u4e2a'\u5982\u679c'\u60c5\u5883\u5047\u8bbe\uff1a1. \u5982\u679c\u6bcd\u4eb2\u771f\u7684\u5728\u67d0\u4e00\u5929\u56de\u6765\u4e86\uff08\u5e26\u7740\u5408\u7406\u89e3\u91ca\uff09\uff0c\u5c14\u8304\u4f1a\u539f\u8c05\u5979\u5417\uff1f2. \u5982\u679c\u5b66\u5802\u91cc\u7684\u67d0\u4e2a\u5b69\u5b50\u95ee\u5979'\u5c0f\u7ea2\u5e3d\u5148\u751f\uff0c\u4f60\u8fd8\u60f3\u627e\u4f60\u5988\u5988\u5417\uff1f'\u2014\u2014\u5979\u4f1a\u600e\u4e48\u56de\u7b54\uff1f3. \u5982\u679c\u90a3\u9876\u515c\u5e3d\u7684\u9b54\u529b\u67d0\u4e00\u5929\u6d88\u5931\u4e86\u2014\u2014\u5979\u8fd8\u4f1a\u7ee7\u7eed\u6234\u7740\u5b83\u5417\uff1f\u6bcf\u4e2a\u90fd\u662f\u5177\u4f53\u573a\u666f+\u8be2\u95ee\u89d2\u8272\u53cd\u5e94\uff0c\u4e14\u4e09\u4e2a\u5047\u8bbe\u5206\u522b\u6d4b\u8bd5\u4e86\u5c14\u8304\u5bf9\u6bcd\u4eb2\u3001\u5bf9\u81ea\u6211\u8eab\u4efd\u3001\u5bf9\u9057\u7269\u610f\u4e49\u7684\u6838\u5fc3\u6001\u5ea6\u3002"
        },
        {
          "text": "\u5bf9\u8bdd\u63a2\u8ba8\u4e86\u6846\u67b6\u4e2d\u7684\u7559\u767d\u4e4b\u5904\uff08\u5982\u7ae5\u5e74\u5230\u5192\u9669\u7684\u52a8\u673a\u3001\u5192\u9669\u7ed3\u675f\u56de\u5f52\u7684\u60c5\u611f\u3001\u515c\u5e3d\u5bf9\u5979\u7684\u610f\u4e49\u7b49\uff09\uff0c\u800c\u975e\u8df3\u8fc7\u8fd9\u4e9b\u53ea\u8c08\u5df2\u77e5",
          "passed": true,
          "evidence": "\u7ae5\u5e74\u5230\u5192\u9669\u7684\u52a8\u673a\uff1a\u7b2c7\u8f6e\u8ffd\u95ee'\u5979\u5927\u6982\u591a\u5c11\u5c81\u51fa\u53d1\u7684\uff1f...\u5979\u7684\u76ee\u6807\u4e00\u5f00\u59cb\u5c31\u662f\u5bfb\u627e\u6bcd\u4eb2\u7684\u7ebf\u7d22\uff0c\u8fd8\u662f\u5728\u65c5\u9014\u4e2d\u624d\u6162\u6162\u610f\u8bc6\u5230\u81ea\u5df1\u5728\u627e\u4ec0\u4e48\uff1f'\uff0c\u5f15\u51fa\u8001\u6797\u751f\u75c5\u2192\u8001\u9648\u5934\u6307\u8def\u219217\u5c81\u51fa\u53d1\u7684\u5b8c\u6574\u52a8\u673a\u94fe\u3002\u5192\u9669\u7ed3\u675f\u56de\u5f52\u7684\u60c5\u611f\uff1a\u7b2c8\u8f6e\u8ffd\u95ee'\u8fd9\u79cd\u7ed3\u679c\u5bf9\u5979\u6765\u8bf4\uff0c\u7b97\u662f\u4e00\u79cd\u7b54\u6848\u5417\uff1f...\u662f\u4ec0\u4e48\u8ba9\u5979\u51b3\u5b9a\u572822\u5c81\u505c\u4e0b\u6765\uff0c\u56de\u53bb\uff1f'\uff0c\u5f15\u51fa\u8001\u9648\u5934\u6765\u4fe1\u7684\u60c5\u611f\u8f6c\u6298\u3002\u515c\u5e3d\u7684\u610f\u4e49\uff1a\u7b2c2\u8f6e\u6df1\u6316'\u4e0d\u53ea\u662f\u4e60\u60ef\uff0c\u66f4\u50cf\u662f\u5979\u4e0e\u6bcd\u4eb2\u4e4b\u95f4\u552f\u4e00\u7684\u7269\u7406\u8fde\u63a5'\uff0c\u540e\u7eed\u6301\u7eed\u6df1\u5316\u3002\u6bcf\u5904\u7559\u767d\u5747\u6709\u9488\u5bf9\u6027\u8ffd\u95ee\u3002"
        },
        {
          "text": "\u5bf9\u8bdd\u4e2d\u6709\u81f3\u5c111\u6b21\u9636\u6bb5\u6027\u5c0f\u7ed3",
          "passed": true,
          "evidence": "\u7b2c10\u8f6e\u52a9\u624b\u63d0\u4f9b\u4e86\u4e00\u6b21\u5b8c\u6574\u7684\u4e09\u5c42\u7ed3\u6784\u5c0f\u7ed3\uff1a'\u597d\uff0c\u8ba9\u6211\u5e2e\u4f60\u628a\u5c14\u8304\u6574\u7406\u4e00\u4e0b\u2014\u2014\u4e0d\u662f\u603b\u7ed3\uff0c\u800c\u662f\u628a\u4f60\u4eca\u5929\u6316\u51fa\u6765\u7684\u6240\u6709\u5c42\u6b21\u5f52\u4f4d\uff1a\u8868\u5c42\u8eab\u4efd...\u4e2d\u5c42\u53d9\u4e8b...\u6df1\u5c42\u6838\u5fc3...'\uff0c\u5c06\u89d2\u8272\u6574\u7406\u4e3a'\u56de\u4e61\u6559\u4e66\u7684\u5b88\u62a4\u8005\u2192\u5bfb\u6bcd\u4e94\u5e74\u7684\u5192\u9669\u8005\u2192\u88ab\u7231\u5305\u56f4\u4f46\u4ecd\u4e0d\u5b8c\u6574\u7684\u4eba'\u4e09\u4e2a\u5c42\u6b21\uff0c\u5e76\u9644\u5e26'\u4f60\u89c9\u5f97\u8fd9\u4e2a\u68b3\u7406\u600e\u4e48\u6837\uff1f\u8fd8\u6709\u54ea\u4e2a\u90e8\u5206\u4f60\u89c9\u5f97\u9700\u8981\u7ee7\u7eed\u6df1\u6316\u7684\u5417\uff1f'\u7684\u5f00\u653e\u5f0f\u8ffd\u95ee\u3002\u6b64\u5916\u5bf9\u8bdd\u7ed3\u5c3e\uff08\u7b2c12\u8f6e\u540e\uff09\u8fd8\u6709\u4e00\u4efd\u66f4\u5b8c\u6574\u7684'\u89d2\u8272\u6700\u7ec8\u603b\u7ed3'\u3002"
        },
        {
          "text": "\u5bf9\u8bdd\u8f6e\u6b21\u57286-15\u8f6e\u4e4b\u95f4",
          "passed": true,
          "evidence": "\u5bf9\u8bdd\u8bb0\u5f55\u660e\u786e\u6807\u6ce8\u4e86\u7b2c1\u8f6e\u81f3\u7b2c12\u8f6e\u517112\u4e2a\u5bf9\u8bdd\u8f6e\u6b21\uff0c\u53e6\u6709\u4e00\u8282'\u89d2\u8272\u6700\u7ec8\u603b\u7ed3'\u300212\u8f6e\u843d\u57286-15\u8f6e\u533a\u95f4\u5185\u3002"
        }
      ],
